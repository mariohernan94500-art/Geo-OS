# EcoOrigen Web — Variables de Entorno
# Copiar este archivo como .env y rellenar con valores reales

# SHOPIFY: Genera un nuevo Storefront Access Token en tu panel Shopify
# Panel > Configuración > Aplicaciones > Canales de ventas personalizados
VITE_SHOPIFY_STORE=ecoorigenchile.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=TU_NUEVO_TOKEN_AQUI

# API de GeoCore (para conectar Voren y el asistente)
VITE_GEOCORE_API_URL=https://agent.ecoorigenchile.com
