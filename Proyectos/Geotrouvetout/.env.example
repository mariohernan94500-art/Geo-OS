# ══════════════════════════════════════════════
# GEO OS v1 — Variables de Entorno
# Copiar como .env y completar con valores reales
# ══════════════════════════════════════════════

# ── Telegram ────────────────────────────────
TELEGRAM_BOT_TOKEN=token_de_tu_bot
TELEGRAM_ALLOWED_USER_IDS=94246835
ADMIN_TELEGRAM_ID=94246835

# ── LLM Motors ──────────────────────────────
GEMINI_API_KEY=tu_gemini_key          # Motor principal
ANTHROPIC_API_KEY=tu_claude_api_key   # Fallback 1 — Claude (console.anthropic.com)
CLAUDE_MODEL=claude-sonnet-4-6        # Modelo: claude-sonnet-4-6 | claude-opus-4-6
GROQ_API_KEY=tu_groq_key              # Fallback 1 (gratis)
OPENROUTER_API_KEY=                   # Fallback 2 (opcional)
OPENROUTER_MODEL=openrouter/free

# ── TTS ─────────────────────────────────────
TTS_PROVIDER=google                   # google | elevenlabs | none
ELEVENLABS_API_KEY=                   # Solo si TTS_PROVIDER=elevenlabs

# ── Firebase ────────────────────────────────
# Opción A: ruta al archivo local
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# Opción B: JSON directo (para Railway/VPS sin archivos)
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Shopify (FASE 5 — Admin API) ─────────────
# ⚠️  NUNCA hardcodear en código. Siempre en .env
SHOPIFY_STORE_DOMAIN=ecoorigenchile.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=tu_admin_token_nuevo   # Revoca el anterior comprometido
USD_TO_CLP=950

# ── Base de datos ────────────────────────────
DB_PATH=./memory.db

# ── API / Seguridad ──────────────────────────
JWT_SECRET=cambia_esto_por_una_clave_larga_y_segura
PORT=3000

# ── n8n ─────────────────────────────────────
N8N_BASE_URL=http://192.168.1.100:5678

# ── Control de Tokens (FASE 1) ───────────────
TOKEN_DAILY_LIMIT=100000
TOKEN_MONTHLY_LIMIT=2000000

# ── Agente ──────────────────────────────────
MAX_ITERATIONS=5
